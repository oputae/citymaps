# -----------------------------------------------------------------------------
# City Vibe Maps — environment variables
# -----------------------------------------------------------------------------
# The default app needs NO secrets: geocoding uses /api/geocode (server-side
# Nominatim), and map tiles use a public style URL in code.
#
# For Vercel: Project → Settings → Environment Variables.
# Never commit real API keys to git (.env*.local is gitignored).
# -----------------------------------------------------------------------------

# --- Optional / future (uncomment and set only if you add these integrations) ---

# Mapbox (vector tiles, geocoding, etc.)
# MAPBOX_SECRET_TOKEN=
# NEXT_PUBLIC_MAPBOX_TOKEN=

# MapTiler, Stadia, or other hosted tile providers that issue keys
# NEXT_PUBLIC_MAPTILER_KEY=

# Analytics (examples)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# SENTRY_DSN=

# Custom geocoder backend (if you replace Nominatim)
# GEOCODE_API_URL=
# GEOCODE_API_KEY=
